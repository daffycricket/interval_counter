{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MiniFigma",
  "type": "object",
  "required": [
    "meta",
    "tokens",
    "screen",
    "components",
    "qa"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "screenName",
        "snapshotRef"
      ]
    },
    "tokens": {
      "type": "object"
    },
    "screen": {
      "type": "object",
      "required": [
        "size"
      ]
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "bbox"
        ]
      }
    },
    "qa": {
      "type": "object"
    }
  }
}