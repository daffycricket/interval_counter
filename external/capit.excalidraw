    {
      "id": "rBEaWw7P9KEfbjdT1NtBj",
      "type": "text",
      "x": -9660.441571043426,
      "y": 78.94131181593548,
      "width": 1418.2916259765625,
      "height": 495,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aj",
      "roundness": null,
      "seed": 1870143801,
      "version": 1197,
      "versionNonce": 1430068407,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760598560210,
      "link": null,
      "locked": false,
      "text": "Les compléments de specs ne fonctionnent pas toujours bien.\nIci, les valeurs par défaut de la section démarrage rapide sont incorrectes.\nEn revanche, la carte par défaut de la liste est correcte.\n\n\n\nIdées : \n- être plus précis dans ma section de valeurs par défaut\n- demander à l'agent d'arrêter la phase de spec et de lister dans un template de \nde complément d'informations ses questions et ses hypothèeses.\nje répondrais, et ensuite il partirait sur l'implémentation.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Les compléments de specs ne fonctionnent pas toujours bien.\nIci, les valeurs par défaut de la section démarrage rapide sont incorrectes.\nEn revanche, la carte par défaut de la liste est correcte.\n\n\n\nIdées : \n- être plus précis dans ma section de valeurs par défaut\n- demander à l'agent d'arrêter la phase de spec et de lister dans un template de \nde complément d'informations ses questions et ses hypothèeses.\nje répondrais, et ensuite il partirait sur l'implémentation.",
      "autoResize": true,
      "lineHeight": 1.25
    },
