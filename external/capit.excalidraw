      "text": "Enseignement sur les règles contradictoires",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enseignement sur les règles contradictoires",
      "autoResize": true,
