    },
    {
      "id": "xTPE_YzP8bpRYXs7OOu6Z",
      "type": "text",
      "x": -9682.657263364179,
      "y": 1572.283658457028,
      "width": 1211.975830078125,
      "height": 405,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "an",
      "roundness": null,
      "seed": 233958967,
      "version": 1756,
      "versionNonce": 1175162167,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760873942535,
      "link": null,
      "locked": false,
      "text": "Des règles contradictoires résultent en des résultats inconsistents.\nIci, le style du slider est incorrect par rapport à ce que j'attends : \n- une épaisseur plus faible (ici c'est 4, j'attendais 1)\n- la même épaisseur avant et après le point\n\nJ'avais des règles contradictoires dans UI_MAPPING_GUIDE.md et \nUI_MAPPING_GUIDE_EXAMPLE.md \n\n=> S'assurer qu'on n'a pas d'inconsistence",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Des règles contradictoires résultent en des résultats inconsistents.\nIci, le style du slider est incorrect par rapport à ce que j'attends : \n- une épaisseur plus faible (ici c'est 4, j'attendais 1)\n- la même épaisseur avant et après le point\n\nJ'avais des règles contradictoires dans UI_MAPPING_GUIDE.md et \nUI_MAPPING_GUIDE_EXAMPLE.md \n\n=> S'assurer qu'on n'a pas d'inconsistence",
      "autoResize": true,
      "lineHeight": 1.25
    },
